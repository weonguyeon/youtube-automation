# 배포 모드: cli (Claude MAX) / api (Claude API)
DEPLOY_MODE=cli

# 채널 브랜드 컬러 (한 번 선택, 모든 영상에 일관 적용)
# 옵션: midnight_navy, ocean_blue, sunset_orange, forest_green,
#        royal_purple, coral_pink, gold_premium, mono_gray
BRAND_COLOR_PRESET=midnight_navy

# Claude API (배포용)
ANTHROPIC_API_KEY=

# ElevenLabs TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# YouTube Data API
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Flux 이미지 생성
FLUX_API_KEY=

# Pexels 무료 이미지 검색 (https://www.pexels.com/api/)
PEXELS_API_KEY=

# FFmpeg 경로 (기본: ffmpeg)
FFMPEG_PATH=ffmpeg
